{
  "manifestVersion": 3,
  "id": "openpets.cc-switch",
  "name": "CC Switch 用量监控助手",
  "description": "监控 CC Switch 代理网关的 Token 消耗、大模型调用次数与花费，并联动桌面宠物进行气泡吐槽和心情反馈。",
  "version": "1.0.0",
  "runtime": "javascript",
  "sdkVersion": "3.0.0",
  "entry": "index.js",
  "permissions": [
    "network",
    "schedule",
    "pet:speak",
    "pet:reaction",
    "pet:pin",
    "pet:interact",
    "ui:panel",
    "status",
    "commands",
    "network:write"
  ],
  "network": {
    "hosts": [
      "127.0.0.1",
      "localhost",
      "keyvalue.immanuel.co"
    ]
  },
  "configSchema": {
    "vpsUrl": {
      "type": "text",
      "default": "http://127.0.0.1:25722",
      "label": "VPS 服务地址"
    },
    "pollInterval": {
      "type": "select",
      "default": "15s",
      "options": [
        { "label": "10秒", "value": "10s" },
        { "label": "15秒", "value": "15s" },
        { "label": "30秒", "value": "30s" },
        { "label": "60秒", "value": "60s" }
      ],
      "label": "数据更新频率"
    },
    "costThreshold": {
      "type": "number",
      "default": 0.1,
      "label": "大额花费报警阈值 ($)"
    },
    "tokenThreshold": {
      "type": "number",
      "default": 5000,
      "label": "单次大额 Token 阈值"
    },
    "summaryInterval": {
      "type": "select",
      "default": "30s",
      "options": [
        { "label": "不发送", "value": "never" },
        { "label": "5秒", "value": "5s" },
        { "label": "10秒", "value": "10s" },
        { "label": "30秒", "value": "30s" },
        { "label": "60秒", "value": "60s" }
      ],
      "label": "定时用量报告频率"
    },
    "syncAppKey": {
      "type": "text",
      "default": "cc_switch_sync_default",
      "label": "同步通道 AppKey"
    },
    "tokenRange": {
      "type": "select",
      "default": "today",
      "options": [
        { "label": "今日", "value": "today" },
        { "label": "最近24h", "value": "1d" },
        { "label": "最近7天", "value": "7d" },
        { "label": "最近14天", "value": "14d" },
        { "label": "最近30天", "value": "30d" }
      ],
      "label": "Token 统计区间"
    }
  },
  "panels": {
    "usage-dashboard": "panel.html"
  }
}
