{
  "manifestVersion": 3,
  "id": "openpets.cc-switch",
  "name": "CC Switch 用量监控助手",
  "description": "监控 CC Switch 代理网关的 Token 消耗、大模型调用次数与花费，并联动桌面宠物进行气泡吐槽和心情反馈。",
  "version": "1.0.0",
  "runtime": "javascript",
  "sdkVersion": "3.0.0",
  "entry": "index.js",
  "permissions": [
    "network",
    "schedule",
    "pet:speak",
    "pet:reaction",
    "ui:panel"
  ],
  "network": {
    "hosts": [
      "127.0.0.1",
      "localhost"
    ]
  },
  "configSchema": {
    "agentPort": {
      "type": "number",
      "default": 15722,
      "label": "本地 Agent 端口"
    },
    "pollInterval": {
      "type": "select",
      "default": "15s",
      "options": [
        { "label": "10秒", "value": "10s" },
        { "label": "15秒", "value": "15s" },
        { "label": "30秒", "value": "30s" },
        { "label": "60秒", "value": "60s" }
      ],
      "label": "数据更新频率"
    },
    "costThreshold": {
      "type": "number",
      "default": 0.1,
      "label": "大额花费报警阈值 ($)"
    },
    "tokenThreshold": {
      "type": "number",
      "default": 5000,
      "label": "单次大额 Token 阈值"
    }
  },
  "panels": {
    "usage-dashboard": "panel.html"
  }
}
