{
  "manifestVersion": 3,
  "id": "openpets.cc-switch",
  "name": "CC Switch 用量监控助手",
  "description": "监控 CC Switch 代理网关的 Token 消耗、大模型调用次数与花费，并联动桌面宠物进行气泡吐槽和心情反馈。",
  "version": "1.0.0",
  "runtime": "javascript",
  "sdkVersion": "3.0.0",
  "entry": "index.js",
  "permissions": [
    "network",
    "schedule",
    "pet:speak",
    "pet:reaction",
    "pet:pin",
    "pet:interact",
    "ui:panel",
    "status",
    "commands",
    "network:write"
  ],
  "network": {
    "hosts": [
      "127.0.0.1",
      "localhost",
      "keyvalue.immanuel.co"
    ]
  },
  "configSchema": {
    "agentPort": {
      "type": "number",
      "default": 25722,
      "label": "本地 Agent 端口"
    },
    "pollInterval": {
      "type": "select",
      "default": "15s",
      "options": [
        { "label": "10秒", "value": "10s" },
        { "label": "15秒", "value": "15s" },
        { "label": "30秒", "value": "30s" },
        { "label": "60秒", "value": "60s" }
      ],
      "label": "数据更新频率"
    },
    "costThreshold": {
      "type": "number",
      "default": 0.1,
      "label": "大额花费报警阈值 ($)"
    },
    "tokenThreshold": {
      "type": "number",
      "default": 5000,
      "label": "单次大额 Token 阈值"
    },
    "summaryInterval": {
      "type": "select",
      "default": "30s",
      "options": [
        { "label": "不发送", "value": "never" },
        { "label": "5秒", "value": "5s" },
        { "label": "10秒", "value": "10s" },
        { "label": "30秒", "value": "30s" },
        { "label": "60秒", "value": "60s" }
      ],
      "label": "定时用量报告频率"
    },
    "syncAppKey": {
      "type": "text",
      "default": "cc_switch_sync_default",
      "label": "同步通道 AppKey"
    },
    "tokenRange": {
      "type": "select",
      "default": "today",
      "options": [
        { "label": "今日", "value": "today" },
        { "label": "最近24h", "value": "1d" },
        { "label": "最近7天", "value": "7d" },
        { "label": "最近14天", "value": "14d" },
        { "label": "最近30天", "value": "30d" }
      ],
      "label": "Token 统计区间"
    },
    "usageAlertPrompt": {
      "type": "textarea",
      "default": "你是一只生活在用户桌面上的可爱宠物（名字叫 CC 助手）。\n刚才主人发起了一次大模型调用，消耗了 {delta_tokens} 点 Token，花费了 {delta_cost} 美元。\n当前整个统计区间已累计使用 {current_tokens} 点，累计花费了 {current_cost} 美元。\n请以活泼、可爱、傲娇吐槽的语气对主人进行这发大模型调用的吐槽或鼓励回复。\n如果单次花费较多（例如超过 $0.05 美元）或者单次 Token 较大（例如超过 5000 点），可以吐槽他“败家”或“脑壳要算烧了”；如果花费很少，可以说点鼓励或卖萌的话。\n字数严格控制在 40 字以内，风格要多样、风趣，可以直接开始吐槽，千万不要带有格式前缀，不要说任何废话。",
      "label": "用量吐槽系统提示词"
    },
    "customChatPrompt": {
      "type": "textarea",
      "default": "你是一只生活在用户桌面上的可爱宠物（名字叫 CC 助手）。\n你的职责是陪伴主人，并关注他的大模型用量（当前统计区间（{date_range}）已使用 {current_tokens} 点，累计花费了 {current_cost} 美元）。\n请以活泼、可爱、偶尔傲娇调侃的语气简短回答主人。\n如果当前周期花费较多（例如超过 $1.0 美元），可以吐槽他“败家”；如果花费很少，可以鼓励他继续工作。\n字数严格控制在 50 字以内，不要说任何废话。",
      "label": "普通对话系统提示词"
    }
  },
  "panels": {
    "usage-dashboard": "panel.html"
  }
}
